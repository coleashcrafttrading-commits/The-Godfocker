# ============================================================
# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored and never leaves your machine.
# ============================================================

# --- Alpaca (use your PAPER keys to start) ---
# Get these from https://app.alpaca.markets/  ->  Paper account -> API Keys
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Paper endpoint. Switch to https://api.alpaca.markets for LIVE (later, on purpose).
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Supabase (for storing presets + trade log) ---
# Project Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Dashboard ---
# Simple password to protect the trade buttons on your local dashboard.
DASHBOARD_PASSWORD=changeme
